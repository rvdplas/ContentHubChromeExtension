{
  "name": "content-hub-power-extension",
  "version": "1.0.0",
  "description": "Provides shortcuts to most used Content Hub pages",
  "scripts": {
    "build": "npx ts-node --project tsconfig.scripts.json scripts/build.ts",
    "clean": "npx ts-node --project tsconfig.scripts.json scripts/build.ts clean",
    "dev": "npm run build && npx ts-node --project tsconfig.scripts.json scripts/watch.ts",
    "watch": "npx ts-node --project tsconfig.scripts.json scripts/watch.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rvdplas/ContentHubChromeExtension.git"
  },
  "author": "Yvo Geldhof & Ronald van der Plas",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/rvdplas/ContentHubChromeExtension/issues"
  },
  "homepage": "https://github.com/rvdplas/ContentHubChromeExtension#readme",
  "devDependencies": {
    "@types/chrome": "^0.0.210",
    "eslint": "^8.9.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.0"
  }
}
